{
    "name": "phenogram/gateway-bindings",
    "description": "Strictly typed PHP bindings for the Telegram Gateway API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "gateway",
        "otp",
        "telegram",
        "verification"
    ],
    "homepage": "https://github.com/phenogram/gateway-bindings",
    "support": {
        "issues": "https://github.com/phenogram/gateway-bindings/issues",
        "source": "https://github.com/phenogram/gateway-bindings"
    },
    "autoload": {
        "psr-4": {
            "Phenogram\\GatewayBindings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phenogram\\GatewayBindings\\Examples\\": "examples/",
            "Phenogram\\GatewayBindings\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "Nikolai Shangin",
            "email": "shanginn@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.50"
    },
    "scripts": {
        "check": [
            "composer validate --strict",
            "@lint:tools",
            "@test",
            "@examples",
            "@phpstan",
            "@style"
        ],
        "examples": [
            "php examples/offline.php",
            "php examples/send-verification.php"
        ],
        "fix": [
            "./tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --sequential"
        ],
        "lint:tools": [
            "@composer --working-dir=tools/phpstan validate --strict",
            "@composer --working-dir=tools/php-cs-fixer validate --strict"
        ],
        "phpstan": [
            "php -d xdebug.mode=off ./tools/phpstan/vendor/bin/phpstan analyse --memory-limit=2G --configuration=phpstan.neon --debug --no-progress"
        ],
        "style": [
            "./tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php --allow-risky=yes --sequential"
        ],
        "test": [
            "./vendor/bin/phpunit"
        ],
        "tools:install": [
            "@composer install --working-dir=tools/phpstan --no-interaction --prefer-dist --no-progress",
            "@composer install --working-dir=tools/php-cs-fixer --no-interaction --prefer-dist --no-progress"
        ]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    }
}
